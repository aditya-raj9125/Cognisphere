{
  "family": "cognisphere-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::612822777688:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::612822777688:role/cognisphereTaskRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "612822777688.dkr.ecr.us-east-1.amazonaws.com/cognisphere-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" },
        { "name": "AWS_REGION", "value": "us-east-1" }
      ],
      "secrets": [
        { "name": "NEO4J_URI:neo4j+s://196dcbdc.databases.neo4j.io", "valueFrom": "arn:aws:ssm:us-east-1:612822777688:parameter/cognisphere/neo4j-uri" },
        { "name": "196dcbdc", "valueFrom": "arn:aws:ssm:us-east-1:612822777688:parameter/cognisphere/neo4j-username" },
        { "name": "xS39NVCGD9UQZd5gpWj9lvs-2nVot3x9HYJAJr0SCdw", "valueFrom": "arn:aws:ssm:us-east-1:612822777688:parameter/cognisphere/neo4j-password" },
        { "name": "AIzaSyB0_4FI1XitY2BCik_amZfYlXO4owzKXp0", "valueFrom": "arn:aws:ssm:us-east-1:612822777688:parameter/cognisphere/google-api-key" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/cognisphere-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8080/actuator/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
