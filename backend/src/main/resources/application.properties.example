spring.application.name=cognisphere

# AWS Configuration
# Credentials: Use environment variables (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY),
# ~/.aws/credentials file, or IAM roles for EC2/ECS.
aws.region=${AWS_REGION:us-east-1}
aws.s3.bucket=${AWS_S3_BUCKET:cognisphere-storage}
aws.bedrock.modelId=${AWS_BEDROCK_MODEL_ID:anthropic.claude-3-sonnet-20240229-v1:0}
aws.bedrock.embeddingModelId=${AWS_BEDROCK_EMBEDDING_MODEL_ID:amazon.titan-embed-text-v1}

# Neo4j
spring.neo4j.uri=${NEO4J_URI:bolt://neo4j:7687}
spring.neo4j.authentication.username=${NEO4J_USERNAME:}
spring.neo4j.authentication.password=${NEO4J_PASSWORD:}

server.address=0.0.0.0
server.port=${SERVER_PORT:8080}

spring.servlet.multipart.max-file-size=30MB
spring.servlet.multipart.max-request-size=30MB

# CORS
cors.allowed-origins=${CORS_ALLOWED_ORIGINS:http://localhost:5173,http://localhost:5174}

# Google Custom Search (for YouTube recommendations)
google.api.key=${GOOGLE_API_KEY:}
google.customsearch.cx=${GOOGLE_CSE_CX:}
google.customsearch.search-url=https://www.googleapis.com/customsearch/v1
