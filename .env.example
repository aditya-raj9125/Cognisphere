# Copy this file to .env and fill in your values
# Used by docker-compose when building/running containers

# Set to your EC2 public IP or domain
VITE_API_URL=http://YOUR_EC2_PUBLIC_IP:8080

# Must match VITE_API_URL's origin so browser can reach backend
CORS_ALLOWED_ORIGINS=http://YOUR_EC2_PUBLIC_IP:3000
